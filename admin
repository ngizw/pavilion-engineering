<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pavilion Engineering - Content Manager</title>
  <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
</head>
<body>
</body>
</html>


backend:
  name: github
  repo: YOUR_GITHUB_USERNAME/YOUR_REPO_NAME # Replace with your details
  branch: main

media_folder: "images/uploads"
public_folder: "/images/uploads"

collections:
  - name: "projects"
    label: "Projects Portfolio"
    folder: "_projects"
    create: true
    slug: "{{slug}}"
    fields:
      - { label: "Project Title", name: "title", widget: "string" }
      - { label: "Location", name: "location", widget: "string" }
      - { label: "Plot UPI Code", name: "upi", widget: "string", required: false }
      - { label: "Status", name: "status", widget: "select", options: ["Ongoing", "Finished"] }
      - { label: "Total Plot Area (SQM)", name: "plotArea", widget: "string", required: false }
      - { label: "Total Built-Up Area (SQM)", name: "builtUpArea", widget: "string", required: false }
      - { label: "Project Image", name: "image", widget: "image" }
      - { label: "Date Added", name: "date", widget: "datetime" }
